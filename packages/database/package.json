{
  "name": "@craft72/database",
  "version": "0.0.0",
  "private": true,
  "description": "Typed PostgreSQL schema and migrations for the CRAFT72 MAX Mini App",
  "type": "module",
  "sideEffects": false,
  "source": "./src/index.ts",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "default": "./dist/schema.js"
    },
    "./source": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "drizzle"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run --config vitest.config.ts",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:check": "drizzle-kit check --config=drizzle.config.ts && sh scripts/check-migration-drift.sh",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts"
  },
  "engines": {
    "node": ">=22.13.0 <25"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
